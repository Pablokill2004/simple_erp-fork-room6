# ============================================================
# .env.example — Copia este archivo a .env y llena los valores
# NUNCA commitees el archivo .env real a git
# ============================================================

# ----------------------------------------------------------
# Django Core
# ----------------------------------------------------------

# Clave secreta de Django. DEBE ser única por entorno.
# Genera una con: python -c "from django.core.signing import get_cookie_signer; import secrets; print(secrets.token_urlsafe(50))"
# Ejemplo: "django-insecure-abc123xyz..." (en dev puede ser cualquier string largo)
SECRET_KEY=django-insecure-CAMBIAME-genera-una-clave-unica-aqui

# Modo debug. En desarrollo: True. En producción: SIEMPRE False.
# Valores válidos: True | False
DEBUG=True

# Hosts permitidos separados por coma. En desarrollo puede ser "*".
# Ejemplo producción: "midominio.com,www.midominio.com"
ALLOWED_HOSTS=*

# ----------------------------------------------------------
# Base de datos PostgreSQL
# ----------------------------------------------------------

# Nombre de la base de datos (debe existir antes de migrar)
# Crear con: CREATE DATABASE tienda;
DB_NAME=tienda

# Usuario de PostgreSQL
# Por defecto PostgreSQL crea el usuario "postgres" al instalarse
DB_USER=postgres

# Contraseña del usuario de PostgreSQL
# La defines tú al instalar PostgreSQL o con: ALTER USER postgres PASSWORD 'nueva_pass';
DB_PASSWORD=CAMBIAME_password_de_tu_postgres

# Host donde corre PostgreSQL
# En desarrollo local: 127.0.0.1
# Con docker-compose: db  (nombre del servicio en docker-compose.yml)
DB_HOST=127.0.0.1

# Puerto de PostgreSQL. Por defecto siempre es 5432.
DB_PORT=5432

# ----------------------------------------------------------
# Email / SMTP (para envío de albaranes y facturas)
# ----------------------------------------------------------

# Servidor SMTP de tu proveedor de email
# Gmail: smtp.gmail.com | Outlook: smtp.office365.com
SMTP_SERVER=smtp.gmail.com

# Puerto SMTP. 587 para TLS (recomendado). 465 para SSL.
SMTP_PORT=587

# Tu dirección de email (la que envía)
SMTP_USERNAME=tu_email@gmail.com

# Contraseña de tu email o App Password si usas Gmail con 2FA
# Gmail: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=CAMBIAME_tu_contrasena_smtp

# Email que aparece como remitente
SENDER_EMAIL=tu_email@gmail.com

# Email que recibe los albaranes/facturas generados
RECEIVER_EMAIL=destinatario@ejemplo.com